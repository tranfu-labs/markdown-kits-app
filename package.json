{
  "name": "markdown-kits-app",
  "version": "1.0.0",
  "description": "WeChat-ready Markdown layout editor with local image handling and share links.",
  "main": "dist-server/server/index.js",
  "scripts": {
    "dev": "concurrently -k -n api,web \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build && npm run build:server && node scripts/check-bundle-size.mjs",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "NODE_ENV=production node dist-server/server/index.js",
    "preview": "npm run build && npm run start",
    "render:markdown": "tsx scripts/render-markdown.ts",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "check": "npm run test && npm run build"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "dompurify": "^3.4.11",
    "express": "^5.2.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.21.0",
    "markdown-it": "^14.2.0",
    "mermaid": "^11.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "turndown": "^7.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^28.0.3",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "concurrently": "^10.0.3",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.4",
    "vitest": "^4.1.9"
  }
}
